generator client {
  provider = "prisma-client-js"
}

 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String   @id @default(uuid())
  cliente     String    
  produto        String
  quantidade  Int
  status    String @default("Recebido")
  data      DateTime @default(now())
  @@map("orders")
}